# Palworld Admin Panel — configuration
#
# Copy to .env next to app.py and edit. The systemd unit loads this file.
# .env is gitignored; never commit real credentials.
#
# Quote any value containing spaces or special characters. systemd strips
# the quotes, and quoting also keeps the file safe to `source` from a shell.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Your Palworld server's admin password — the ADMIN_PASSWORD value from the
# GAME server's own config (docker-compose.yml / PalWorldSettings.ini).
# The REST API refuses everything without it.
PALWORLD_ADMIN_PASSWORD="changeme"

# ---------------------------------------------------------------------------
# Game server location
# ---------------------------------------------------------------------------

# Docker container name of the game server.
PALWORLD_CONTAINER=palworld

# Directory containing the game server's docker-compose.yml. Used by the
# panel's Update / Backup / Restore actions.
PALWORLD_COMPOSE_DIR=/srv/gameservers/palworld

# Usually derived from the above — override only for non-standard layouts.
#PALWORLD_DATA_DIR=/srv/gameservers/palworld/data
#PALWORLD_BACKUP_DIR=/srv/gameservers/palworld/data/backups
#PALWORLD_ARCHIVE_DIR=/srv/gameservers/palworld/archives
#PALWORLD_PAL_DIR=/srv/gameservers/palworld/data/Pal

# REST API base URL AS SEEN FROM INSIDE the game container. Port 8212 is
# normally unpublished, so calls are proxied via `docker exec`.
#PALWORLD_REST_URL=http://127.0.0.1:8212/v1/api

# IMPORTANT: must match the TZ of the GAME container (the TZ env var in its
# compose file), not this host's. Palworld writes log timestamps in local
# time; a mismatch skews every "x minutes ago" in Chat / Recent Players.
PALWORLD_LOG_TZ=UTC

# ---------------------------------------------------------------------------
# Panel
# ---------------------------------------------------------------------------

PANEL_TITLE="Palworld Admin"

# Bind address. Use 127.0.0.1 if your reverse proxy runs on THIS host.
# Use 0.0.0.0 only if the proxy is on another machine — and firewall the
# port to that machine (see README "Network exposure").
PANEL_BIND=0.0.0.0
PANEL_PORT=8300

# Where the panel keeps its own state (pins.json, trails.db, events.db) and
# looks for map.png. Keep this OUTSIDE the git checkout so `git pull` never
# touches your data. Defaults to the app directory if unset.
PANEL_DATA_DIR=/var/lib/palworld-admin

# Comma-separated mount points for the disk-usage card.
PANEL_DISK_PATHS=/,/srv/gameservers

# ---------------------------------------------------------------------------
# Map calibration (see docs/MAP_CALIBRATION.md)
# ---------------------------------------------------------------------------
# Only valid for YOUR map.png. Defaults assume an image covering the full
# -1000..1000 world bounds edge to edge. If your image is cropped or padded,
# players will render offset until you re-fit these.
#MAP_FX_SLOPE=0.0005
#MAP_FX_OFFSET=0.5
#MAP_FY_SLOPE=-0.0005
#MAP_FY_OFFSET=0.5

# ---------------------------------------------------------------------------
# Optional: Umami analytics (leave blank to emit no tracking script at all)
# ---------------------------------------------------------------------------
#UMAMI_WEBSITE_ID=
#UMAMI_HOST_URL=https://panel.example.com
#UMAMI_SCRIPT_URL=/_a/script.js
